<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Webapi:etc/webapi.xsd">
    <route url="/V1/restricted-shipping/validate/:cartId/:postcode" method="GET">
        <service class="GDMexico\RestrictedShipping\Api\ValidateCheckoutInterface" method="validate"/>
        <resources>
            <resource ref="anonymous"/>
        </resources>
    </route>
</routes>
